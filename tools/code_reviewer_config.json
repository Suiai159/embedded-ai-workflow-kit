{
  "source_dirs": [],
  "exclude_dirs": [],
  "isr_functions": [],
  "forbidden_in_isr": [
    "printf",
    "sprintf",
    "fprintf",
    "malloc",
    "free"
  ],
  "max_stack_buffer": 256,
  "check_rules": {
    "isr_blocking": true,
    "infinite_loop": true,
    "stack_usage": true,
    "gpio_config": false,
    "pwm_config": false,
    "magic_number": true,
    "clock_enable": false,
    "freertos_task": true,
    "comment_quality": false
  },
  "notes": [
    "This is a generic workflow-kit default. Add project-specific source_dirs, ISR callbacks, vendor/platform rules, timing checks, and resource constraints after adoption."
  ],
  "severity_weights": {
    "critical": 10,
    "warning": 5,
    "suggestion": 1
  }
}
